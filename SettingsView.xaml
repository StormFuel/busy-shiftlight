<UserControl x:Class="BusylightShiftLight.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Padding="20">
    <StackPanel>
        <TextBlock Text="Busylight Shift Light Settings" FontSize="18" FontWeight="Bold" Margin="0,0,0,20" />

        <!-- Fallback Shift RPM Percentage -->
        <TextBlock Text="Fallback Shift RPM (%)" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBlock Text="Used when car doesn't provide a shift point" FontSize="11" Foreground="Gray" Margin="0,0,0,4" />
        <DockPanel Margin="0,0,0,12">
            <TextBlock x:Name="FallbackShiftRpmValue" DockPanel.Dock="Right" Width="40" TextAlignment="Right" VerticalAlignment="Center" />
            <Slider x:Name="FallbackShiftRpmSlider" Minimum="0.80" Maximum="1.00" TickFrequency="0.01" IsSnapToTickEnabled="True" />
        </DockPanel>

        <!-- Yellow Warning Threshold -->
        <TextBlock Text="Yellow Warning Threshold (%)" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBlock Text="Percentage of shift RPM to trigger yellow warning" FontSize="11" Foreground="Gray" Margin="0,0,0,4" />
        <DockPanel Margin="0,0,0,12">
            <TextBlock x:Name="YellowThresholdValue" DockPanel.Dock="Right" Width="40" TextAlignment="Right" VerticalAlignment="Center" />
            <Slider x:Name="YellowThresholdSlider" Minimum="0.70" Maximum="0.95" TickFrequency="0.01" IsSnapToTickEnabled="True" />
        </DockPanel>

        <!-- Flash Interval -->
        <TextBlock Text="Flash Interval (ms)" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBlock Text="Red warning flash on/off toggle speed" FontSize="11" Foreground="Gray" Margin="0,0,0,4" />
        <DockPanel Margin="0,0,0,12">
            <TextBlock x:Name="FlashIntervalValue" DockPanel.Dock="Right" Width="50" TextAlignment="Right" VerticalAlignment="Center" />
            <Slider x:Name="FlashIntervalSlider" Minimum="20" Maximum="200" TickFrequency="5" IsSnapToTickEnabled="True" />
        </DockPanel>

        <!-- Yellow Color -->
        <TextBlock Text="Yellow Warning Color" FontWeight="SemiBold" Margin="0,0,0,4" />
        <DockPanel Margin="0,0,0,12">
            <Rectangle x:Name="YellowColorPreview" Width="24" Height="24" DockPanel.Dock="Right" Margin="8,0,0,0" Stroke="Gray" StrokeThickness="1" Fill="#FFA500" />
            <TextBox x:Name="YellowColorHex" Width="100" HorizontalAlignment="Left" />
        </DockPanel>

        <!-- Red Color -->
        <TextBlock Text="Red Shift Color" FontWeight="SemiBold" Margin="0,0,0,4" />
        <DockPanel Margin="0,0,0,12">
            <Rectangle x:Name="RedColorPreview" Width="24" Height="24" DockPanel.Dock="Right" Margin="8,0,0,0" Stroke="Gray" StrokeThickness="1" Fill="#FF0000" />
            <TextBox x:Name="RedColorHex" Width="100" HorizontalAlignment="Left" />
        </DockPanel>
    </StackPanel>
</UserControl>
